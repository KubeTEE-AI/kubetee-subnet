# =============================================================================
# KubeTEE AI Subnet - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d

# =============================================================================
# Docker Image Configuration
# =============================================================================

# Docker image to use (default: ghcr.io/kubetee-ai/kubetee-subnet:latest)
IMAGE=ghcr.io/kubetee-ai/kubetee-subnet:latest

# =============================================================================
# Blockchain Configuration (Ethereum/BASE L2)
# =============================================================================

# RPC URL for Ethereum node (local Hardhat or remote)
# Local: http://kubetee-hardhat:8545
# BASE Sepolia: https://sepolia.base.org
# BASE Mainnet: https://mainnet.base.org
RPC_URL=http://kubetee-hardhat:8545

# Deployed GitHub Registry contract address
# Leave empty for local development (will be set after deployment)
GITHUB_REGISTRY_CONTRACT_ADDRESS=

# Validator private key for signing transactions (with 0x prefix)
# For local development, use Hardhat's first test account:
# DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# VALIDATOR_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
VALIDATOR_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# =============================================================================
# GitHub Configuration
# =============================================================================

# GitHub Personal Access Token for higher API rate limits
# Create at: https://github.com/settings/tokens
# Required scopes: none (public repo access only)
GITHUB_TOKEN=

# =============================================================================
# Bittensor Configuration
# =============================================================================

# Subnet Network UID
NETUID=62

# Subtensor network (test, finney, local)
SUBTENSOR_NETWORK=test

# Validator wallet configuration
WALLET_NAME=validator
WALLET_HOTKEY=default

# Miner wallet configuration
MINER_WALLET_NAME=miner
MINER_WALLET_HOTKEY=default

# Path to Bittensor wallet directory on host
BITTENSOR_VOLUME_PATH=~/.bittensor

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Observability Configuration
# =============================================================================

# Flower (Celery monitoring) authentication
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# =============================================================================
# Development Notes
# =============================================================================

# Hardhat Test Accounts (for local development):
# Account #0: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
#   Private Key: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
#
# Account #1: 0x70997970C51812dc3A010C7d01b50e0d17dc79C8
#   Private Key: 0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
#
# Account #2: 0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
#   Private Key: 0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Quick Start:
# 1. Copy this file to .env
# 2. Start services: docker compose up -d
# 3. Deploy contract: docker compose run --rm kubetee-deploy-contracts
# 4. Copy contract address to GITHUB_REGISTRY_CONTRACT_ADDRESS
# 5. Restart API: docker compose restart kubetee-api
