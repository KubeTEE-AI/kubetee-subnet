@startuml
title <size:24>Component View: KubeTEE Subnet - validator container</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System(BittensorChainSubtensor, "Bittensor Chain (Subtensor)", $descr="Localnet in the dev stack; testnet/finney otherwise. Holds the metagraph, hyperparameters, and set_weights.", $tags="", $link="")

System_Boundary("KubeTEESubnet_boundary", "KubeTEE Subnet", $tags="") {
  Container_Boundary("KubeTEESubnet.validatorcontainer_boundary", "validator container", $tags="") {
    Component(KubeTEESubnet.validatorcontainer.setup_single_nodepy, "setup_single_node.py", $techn="scripts/setup_single_node.py", $descr="Creates subnet if needed, registers/stakes the owner/alice/bob triad from pinned dev seeds, starts emissions, attempts conviction/recycle hypers guarded by a live ownership check.", $tags="", $link="")
    Component(KubeTEESubnet.validatorcontainer.convictionsetterloop, "conviction-setter loop", $techn="docker-compose.yml validator command", $descr="Background btcli sudo loop keeping owner_cut_auto_lock_enabled and recycle_or_burn=Recycle; backs off hard when ownership is verified absent.", $tags="", $link="")
    Component(KubeTEESubnet.validatorcontainer.print_subnet_statspy, "print_subnet_stats.py", $techn="scripts/print_subnet_stats.py", $descr="Background loop printing hypers, stake, ownership, and metagraph stats over one reused chain connection.", $tags="", $link="")
    Component(KubeTEESubnet.validatorcontainer.validator_entrypointpy, "validator_entrypoint.py", $techn="scripts/validator_entrypoint.py", $descr="Runs btcli registration + hyperparam setup, then execs the basic validator.", $tags="", $link="")
  }

  Container(KubeTEESubnet.basic_validatorpy, "basic_validator.py", $techn="Python process (foreground)", $descr="One validator loop, one chain connection, one Rancher session: metagraph -> Rancher enumeration -> reconciliation -> scoring -> weights -> log + metrics.", $tags="", $link="")
}

Rel(KubeTEESubnet.validatorcontainer.validator_entrypointpy, KubeTEESubnet.validatorcontainer.setup_single_nodepy, "Runs btcli registration and hyperparam setup", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.validatorcontainer.setup_single_nodepy, BittensorChainSubtensor, "Creates subnet, registers/stakes triad, starts emissions, sets hypers (ownership permitting)", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.validatorcontainer.convictionsetterloop, BittensorChainSubtensor, "btcli sudo set owner_cut_auto_lock_enabled + recycle_or_burn", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.validatorcontainer.print_subnet_statspy, BittensorChainSubtensor, "Reads hypers, stake, and metagraph stats", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.validatorcontainer.validator_entrypointpy, KubeTEESubnet.basic_validatorpy, "execs as foreground process", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.basic_validatorpy, BittensorChainSubtensor, "Reads metagraph; sets alice-signed weights", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.basic_validatorpy, BittensorChainSubtensor, "Reads metagraph; submits set_weights", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml