@startuml
title <size:24>Container View: KubeTEE Subnet</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

System(BittensorChainSubtensor, "Bittensor Chain (Subtensor)", $descr="Localnet in the dev stack; testnet/finney otherwise. Holds the metagraph, hyperparameters, and set_weights.", $tags="", $link="")
System(Rancher, "Rancher", $descr="Cluster-management API the validator reads (read-only v3 API, plus one guarded reconciliation DELETE). Dev stack runs a self-contained containerised Rancher.", $tags="", $link="")

System_Boundary("KubeTEESubnet_boundary", "KubeTEE Subnet", $tags="") {
  Container(KubeTEESubnet.basic_validatorpy, "basic_validator.py", $techn="Python process (foreground)", $descr="One validator loop, one chain connection, one Rancher session: metagraph -> Rancher enumeration -> reconciliation -> scoring -> weights -> log + metrics.", $tags="", $link="")
  Container(KubeTEESubnet.rancherinit, "rancher-init", $techn="scripts/rancher_provision.sh (alpine)", $descr="One-shot provisioner: logs in to Rancher, mints the validator API token, imports and labels the miner-cluster, publishes token + CA to a shared volume.", $tags="", $link="")
  Container(KubeTEESubnet.miner1stub, "miner-1 (stub)", $techn="Docker (profile: with-miners)", $descr="Optional with-miners profile stub reusing the validator image; placeholder for mock miners.", $tags="", $link="")
  Container(KubeTEESubnet.validatorcontainer, "validator container", $techn="Python 3.13, uv, Docker", $descr="Single container (Dockerfile.validator) that runs btcli setup, background loops, and the basic validator.", $tags="", $link="")
}

Rel(KubeTEESubnet.validatorcontainer, BittensorChainSubtensor, "Creates subnet, registers/stakes triad, starts emissions, sets hypers (ownership permitting)", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.validatorcontainer, KubeTEESubnet.basic_validatorpy, "execs as foreground process", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.basic_validatorpy, BittensorChainSubtensor, "Reads metagraph; sets alice-signed weights", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.basic_validatorpy, Rancher, "Read-only v3 API over pinned https origin + guarded DELETE", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.rancherinit, Rancher, "Mints token; imports miner-cluster", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.basic_validatorpy, BittensorChainSubtensor, "Reads metagraph; submits set_weights", $techn="", $tags="", $link="")
Rel(KubeTEESubnet.miner1stub, BittensorChainSubtensor, "Connects (stub)", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml