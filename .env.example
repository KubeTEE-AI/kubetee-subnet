# KubeTEE subnet validator configuration - NAMES ONLY.
# Copy to .env (gitignored) and fill in real values there. Secret values
# must NEVER be committed, logged, or pasted into docs/issues.

# --- Rancher v3 API --------------------------------------------------------
# The validator refuses to start without a Rancher URL + bearer token (D14).
# NOTE: the docker-compose dev stack is self-contained - it runs its own
# Rancher (the `rancher` service) and `rancher-init` mints the token
# automatically each `up`, so you do NOT need to set these for `docker
# compose up`. Set them only to run the validator against an EXTERNAL Rancher
# outside the compose stack. RANCHER_URL must be a https origin.
RANCHER_URL=
RANCHER_BEARER_TOKEN=
# Optional outside root Compose: custom CA bundle used only by Rancher HTTP.
# Root external Compose requires a host path and mounts it at this container path.
RANCHER_CA_FILE=
# The combined validator/reconciler credential needs cluster/node GET/list
# plus cluster DELETE only; it is not an admin or read-only token.

# --- Required validation identity and policy ------------------------------
# Chain-network identity embedded in the canonical enrollment binding. This
# is not the websocket/RPC endpoint configured by BT_NETWORK.
KUBETEE_CHAIN_NETWORK=finney
# External validators use production. The disposable local compose overlay
# supplies debug explicitly; debug is never an implicit fallback.
KUBETEE_VALIDATION_PROFILE=production
# Production refuses implicit local-chain/dev-wallet defaults.
BT_NETWORK=finney
BT_WALLET=validator
BT_WALLET_HOTKEY=default
KUBETEE_SUBNET_NETUID=90
KUBETEE_VALIDATOR_HOTKEY=

# --- Validator tunables (plan-pinned defaults shown) ------------------------
# Weight split (D12): miner share in [0, 1]; owner recycle share is 1 - value.
KUBETEE_MINER_SHARE=0.10
# Validation loop interval in seconds (minimum 60).
KUBETEE_POLL_SECONDS=60
# Consecutive skipped cycles before loud degraded mode (D10 staleness bound).
KUBETEE_MAX_CONSECUTIVE_SKIPS=10
# Deregistration-reconciliation thresholds (spec 4.2a): absence must persist
# >= both values before the single guarded cluster removal may fire.
KUBETEE_RECONCILE_MIN_CYCLES=3
KUBETEE_RECONCILE_MIN_SECONDS=900
